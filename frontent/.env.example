# Public site URL (no trailing slash) — enables canonical, Open Graph, Twitter cards, sitemap.xml, robots Sitemap line.
# Set on Render to your real domain, e.g. https://playsocial.com — optional; app works without it.
# VITE_PUBLIC_SITE_URL=https://your-domain.com

# Optional — Google AdSense publisher ID (format: ca-pub-xxxxxxxxxxxxxxxx).
# Leave unset until AdSense approves your site; the app works the same without it.
# After approval, set in Render (or .env.local) and redeploy:
# VITE_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
#
# Optional — allow AdSense script on localhost for testing only:
# VITE_ADSENSE_ALLOW_DEV=true

# Optional — Adsterra Native Banner in the home feed (web).
# Defaults match the playsocial.social Native Banner unit if unset.
# VITE_ADSTERRA_NATIVE_SCRIPT=https://pl30475410.effectivecpmnetwork.com/fc74cc04657e9bfb73f4a6bff8084c15/invoke.js
# VITE_ADSTERRA_NATIVE_CONTAINER=container-fc74cc04657e9bfb73f4a6bff8084c15
#
# Insert an ad every N posts (1 = between each post):
# VITE_ADSTERRA_FEED_EVERY=1
#
# Allow on localhost for testing:
# VITE_ADSTERRA_ALLOW_DEV=true
